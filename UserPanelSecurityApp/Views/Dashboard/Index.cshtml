@model IEnumerable<UserPanelSecurityApp.Models.UserNote>
@{
    ViewData["Title"] = "Your Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Welcome to your Private Dashboard</h2>
    <form asp-controller="Account" asp-action="Logout" method="post">
        <button type="submit" class="btn btn-outline-danger">Log Out</button>
    </form>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm p-3">
            <h4>Add Private Note</h4>
            <form asp-action="AddNote" method="post">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <textarea name="content" class="form-control" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Save Note</button>
            </form>
        </div>
    </div>

    <div class="col-md-8">
        <h4>Your Secure Notes</h4>
        @if (!Model.Any())
        {
            <p class="text-muted">No personal notes found.</p>
        }
        else
        {
            @foreach (var note in Model)
            {
                <div class="card mb-2 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@note.Title</h5>
                        <p class="card-text">@note.Content</p>
                        <small class="text-muted">Created: @note.CreatedAt.ToLocalTime()</small>
                    </div>
                </div>
            }
        }
    </div>
</div>